# PolyTheater 环境变量模板

# ===================
# LLM 配置（必填）
# ===================

# OpenAI 兼容的 API Key
LLM_API_KEY=your-api-key-here

# API 基础 URL（可选，默认 OpenAI）
# LLM_BASE_URL=https://api.openai.com/v1

# 模型名称（可选）
# LLM_MODEL_NAME=gpt-4o-mini

# ===================
# Zep 知识图谱配置（必填）
# ===================

ZEP_API_KEY=your-zep-api-key-here

# ===================
# 模拟配置（可选）
# ===================

# 默认最大模拟轮数
# DEFAULT_MAX_ROUNDS=144

# 默认每轮时间（分钟）
# DEFAULT_MINUTES_PER_ROUND=60

# 默认活跃 Agent 范围
# DEFAULT_ACTIVE_AGENTS_MIN=5
# DEFAULT_ACTIVE_AGENTS_MAX=20

# ===================
# 服务器配置（可选）
# ===================

# Flask 配置
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5001
# FLASK_DEBUG=false

# 上传文件夹
# UPLOAD_FOLDER=uploads

# 最大上传大小（字节）
# MAX_CONTENT_LENGTH=52428800

# ===================
# CORS 配置（可选）
# ===================

# CORS 允许的源，多个源用逗号分隔
# 开发环境：http://localhost:3000,http://localhost:5173
# 生产环境：https://yourdomain.com
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173
