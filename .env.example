# NovelWriter Configuration Template
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Provider Selection
# =============================================================================
# Supported providers: deepseek, infini, glm, bailian, volcengine, kimi, gemini
LLM_PROVIDER=deepseek

# =============================================================================
# LLM Settings (Common)
# =============================================================================
# Leave empty to use provider's default model
DEFAULT_LLM_MODEL=
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# =============================================================================
# DeepSeek Configuration (Default Provider)
# =============================================================================
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# =============================================================================
# Infini AI Configuration
# =============================================================================
# Infini AI provides access to multiple models via unified API
INFINI_API_KEY=your-infini-api-key
INFINI_BASE_URL=https://cloud.infini-ai.com/maas/coding/v1

# =============================================================================
# Zhipu GLM Configuration (智谱AI)
# =============================================================================
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# =============================================================================
# Bailian Configuration (阿里百炼)
# =============================================================================
BAILIAN_API_KEY=your-bailian-api-key
BAILIAN_BASE_URL=

# =============================================================================
# Volcengine Configuration (火山引擎)
# =============================================================================
VOLCENGINE_API_KEY=your-volcengine-api-key
VOLCENGINE_BASE_URL=

# =============================================================================
# Kimi Configuration (Moonshot AI)
# =============================================================================
KIMI_API_KEY=your-kimi-api-key
KIMI_BASE_URL=https://api.moonshot.cn/v1

# =============================================================================
# Gemini Configuration
# =============================================================================
# Can use official Google API or third-party proxy
GEMINI_API_KEY=your-gemini-api-key
GEMINI_BASE_URL=https://api.laozhang.ai/v1

# =============================================================================
# Vector Store Settings
# =============================================================================
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_PATH=data/chroma
CHROMA_COLLECTION_NAME=novel-facts
CHROMA_EMBEDDING_MODEL=shibing624/text2vec-base-multilingual

# =============================================================================
# Database Settings
# =============================================================================
REDIS_URL=redis://localhost:6379/0
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/novel_agent

# =============================================================================
# Platform API Keys (For Publishing)
# =============================================================================
WATTPAD_API_KEY=
WATTPAD_API_SECRET=
ROYALROAD_USERNAME=
ROYALROAD_PASSWORD=

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/novel-agent.log

# =============================================================================
# Data Paths
# =============================================================================
OPENVIKING_DATA_DIR=data/openviking