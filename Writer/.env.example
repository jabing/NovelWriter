# Writer Studio - API Keys Configuration
# Copy this file to .env and fill in your actual API keys

# ============================================
# 国内模型 (Domestic Models)
# ============================================

# 1. DeepSeek 官方 API (DeepSeek Official)
# 获取地址: https://platform.deepseek.com/
# 用于: DeepSeek V3 (日常章节 $0.002/1k), DeepSeek R1 (推理章节 $0.004/1k)
DEEPSEEK_API_KEY=sk-your-deepseek-official-key-here

# 2. Infini AI (Kimi K2.5 代理)
# 用于: Kimi K2.5 (中文黄金章 $0.015/1k)
# 注意: Infini 的 Coding Plan 只包含 Kimi，不包含 DeepSeek
INFINI_API_KEY=sk-cp-5bfck6tiavjuqv2b

# 3. 智谱 AI - GLM-5 Coding Plan (已付费)
# 用于: GLM-5 (大纲/架构/系统流 - 免费无限使用)
ZHIPU_API_KEY=7a0c4a13c22d48cda9d648aa82527485.UCIs1spSr9rgh7QR

# ============================================
# 国外模型 (International Models - via Laozhang.ai)
# ============================================

# Laozhang.ai API Key
# 获取地址: https://api.laozhang.ai/
# 包含: GPT-4o/5, Claude 3.5/3.7/Opus-4, Gemini 2.5
LAOZHANG_API_KEY=sk-dxRvT5PyeobdbCbu8b65863f727e4101A3C0646aB6C33dF5

# ============================================
# 其他配置 (Other Settings)
# ============================================

DEFAULT_LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# Memory System
OPENVIKING_DATA_DIR=data/openviking

# Redis (for Celery task queue)
REDIS_URL=redis://localhost:6379/0

# Platform API Keys
WATTPAD_API_KEY=
WATTPAD_API_SECRET=
ROYALROAD_USERNAME=
ROYALROAD_PASSWORD=

# Publishing Settings
AUTO_PUBLISH=false
DEFAULT_PLATFORM=wattpad

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/novel-agent.log
